# P.A.T.H 환경변수 설정 예시
# .env.example 파일을 .env로 복사한 후 실제 값을 입력하세요

# ===== 알리고 카카오톡 알림톡 설정 =====
# 알리고 가입 후 발급받은 API 키
ALIGO_API_KEY=your_aligo_api_key_here

# 알리고 사용자 ID
ALIGO_USER_ID=your_aligo_user_id

# 발신번호 (하이픈 없이 숫자만)
ALIGO_SENDER=01012345678

# 승인받은 알림톡 템플릿 코드
ALIGO_TEMPLATE_CODE=TM_0001

# 카카오톡 채널 ID (@ 포함)
ALIGO_PLUSFRIEND_ID=@your_channel

# 테스트 모드 (true: 실제 발송 없음, false: 실제 발송)
ALIGO_TEST_MODE=false

# 알림톡 실패 시 SMS 자동 발송 여부
ALIGO_SMS_FALLBACK=true

# ===== 다계정 방지 설정 =====
# 한 전화번호당 생성 가능한 최대 계정 수
PHONE_ACCOUNT_LIMIT=2

# ===== 구글 OAuth 로그인 설정 =====
# Google Cloud Console에서 발급
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 백엔드 콜백 URL (Render API 도메인 기준)
GOOGLE_REDIRECT_URI=https://api.sdij.cloud/api/auth/google/callback
# 인증 성공/실패 후 이동할 경로
GOOGLE_AUTH_SUCCESS_REDIRECT=https://sdij.cloud/mainHub/
GOOGLE_AUTH_ERROR_REDIRECT=https://sdij.cloud/login/?error=google_auth

# ===== 서버 설정 =====
# 실행 환경 (development: 개발, production: 운영)
NODE_ENV=development

# 서버 포트
PORT=3000

# ===== 데이터베이스 설정 =====
# PostgreSQL 연결 정보
DB_HOST=localhost
DB_PORT=5432
DB_NAME=path_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# ===== 세션 설정 =====
# 세션 비밀키 (랜덤한 문자열로 변경 필수!)
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# ===== CORS 설정 =====
# 허용할 클라이언트 도메인
CORS_ORIGIN=http://localhost:3000

# ===== 결제 설정 (토스페이먼츠) =====
# 토스페이먼츠 대시보드 > 개발자 > API 키에서 발급
# 테스트 환경: test_sk_... / 운영 환경: live_sk_...
TOSS_SECRET_KEY=test_sk_placeholder_replace_me
# 클라이언트 키 (프론트엔드 shared/payment.js의 TOSS_CLIENT_KEY와 일치해야 함)
TOSS_CLIENT_KEY=test_ck_placeholder_replace_me

# ===== 결제 설정 (Google Play IAP) =====
# Google Play 앱 패키지명 (capacitor.config.json의 appId와 동일)
GOOGLE_PLAY_PACKAGE_NAME=cloud.sdij.path
# Google Cloud > 서비스 계정 JSON 키 (한 줄로 변환하여 입력)
# Google Play Console > 설정 > API 액세스에서 서비스 계정 연결 필요
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ===== 결제 설정 (Apple IAP) =====
# App Store Connect > 앱 > 인앱 구매 > 공유 암호에서 발급
APPLE_IAP_SHARED_SECRET=your_apple_shared_secret_here
