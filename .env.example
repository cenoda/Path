# P.A.T.H 환경변수 설정 예시
# .env.example 파일을 .env로 복사한 후 실제 값을 입력하세요

# ===== 알리고 카카오톡 알림톡 설정 =====
# 알리고 가입 후 발급받은 API 키
ALIGO_API_KEY=your_aligo_api_key_here

# 알리고 사용자 ID
ALIGO_USER_ID=your_aligo_user_id

# 발신번호 (하이픈 없이 숫자만)
ALIGO_SENDER=01012345678

# 승인받은 알림톡 템플릿 코드
ALIGO_TEMPLATE_CODE=TM_0001

# 카카오톡 채널 ID (@ 포함)
ALIGO_PLUSFRIEND_ID=@your_channel

# 테스트 모드 (true: 실제 발송 없음, false: 실제 발송)
ALIGO_TEST_MODE=false

# 알림톡 실패 시 SMS 자동 발송 여부
ALIGO_SMS_FALLBACK=true

# ===== 다계정 방지 설정 =====
# 한 전화번호당 생성 가능한 최대 계정 수
PHONE_ACCOUNT_LIMIT=2

# ===== 구글 OAuth 로그인 설정 =====
# Google Cloud Console에서 발급
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 백엔드 콜백 URL (Render API 도메인 기준)
GOOGLE_REDIRECT_URI=https://api.sdij.cloud/api/auth/google/callback
# 인증 성공/실패 후 이동할 경로
GOOGLE_AUTH_SUCCESS_REDIRECT=https://sdij.cloud/mainHub/
GOOGLE_AUTH_ERROR_REDIRECT=https://sdij.cloud/login/?error=google_auth

# ===== 서버 설정 =====
# 실행 환경 (development: 개발, production: 운영)
NODE_ENV=development

# 서버 포트
PORT=3000

# ===== 데이터베이스 설정 =====
# PostgreSQL 연결 정보
DB_HOST=localhost
DB_PORT=5432
DB_NAME=path_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# ===== 세션 설정 =====
# 세션 비밀키 (랜덤한 문자열로 변경 필수!)
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# ===== CORS 설정 =====
# 허용할 클라이언트 도메인
CORS_ORIGIN=http://localhost:3000
